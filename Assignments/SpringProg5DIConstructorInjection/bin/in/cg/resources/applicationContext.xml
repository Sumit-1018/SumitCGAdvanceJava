<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean class="in.cg.beans.Address" id="AddrId">
    <constructor-arg value="1232"/>
    <constructor-arg value="Delhi"/>
    <constructor-arg value="110044"/>
    </bean>
    
    <bean class="in.cg.beans.Student" id="StdId">
    <constructor-arg value="102"/>
    <constructor-arg value="Sumit"/>
    <constructor-arg value="constructor@email.com"/>
    <constructor-arg ref="AddrId"/>
    </bean>

</beans>