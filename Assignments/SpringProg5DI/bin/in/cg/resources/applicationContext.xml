<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->
    <bean class="in.cg.beans.Address" id="AddrId">
    <property name="hNo" value="1232"/>
    <property name="city" value="Delhi"/>
    <property name="pincode" value="110044"/>
    </bean>
    
    <bean class="in.cg.beans.Student" id="StdId">
    <property name="id" value="102"/>
    <property name="name" value="Sumit"/>
    <property name="email" value="random@email.com"/>
    <property name="a" ref="AddrId"/>
    </bean>

</beans>